# SPDX-License-Identifier: Apache-2.0
# OpenFocus 配置模板（可复制为 .env 使用）
#
# 用法：
# 1) cp .env-default .env
# 2) 填入 API Key
# 3) 在仓库根目录启动服务（使其能读取 cwd/.env）
#
# 注意：
# - 请不要把 .env（真实密钥）提交到仓库
# - 本文件仅示例，不包含真实密钥

# ===== 选择其一：OpenAI-compatible =====
# OPENFOCUS_OPENAI_API_KEY=
# OPENFOCUS_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENFOCUS_OPENAI_MODEL=gpt-4.1-mini

# ===== 选择其一：Ark（OpenAI-compatible） =====
# OPENFOCUS_ARK_API_KEY=
# OPENFOCUS_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENFOCUS_ARK_MODEL=doubao-seed-1-6

# 兼容别名（可选）：
# ARK_API_KEY=
# ARK_BASE_URL=
# ARK_MODEL=

# ===== 其他可选配置 =====
# OpenFocus 实例 id。多实例同时运行时，为每个实例设置不同值。
# 该值会被 make serve、make companion 和 scripts/install_agent_hooks.py 自动读取。
# OPENFOCUS_INSTANCE_ID=default

# OpenFocus Web 服务监听地址（make serve 会读取）
# OPENFOCUS_HOST=127.0.0.1
# OPENFOCUS_PORT=8001

# OpenFocus gRPC server 监听地址（Companion 连接用）
# OPENFOCUS_GRPC_HOST=127.0.0.1
# OPENFOCUS_GRPC_PORT=17891

# Companion 连接的 OpenFocus gRPC 地址（make companion 会读取）
# OPENFOCUS_SERVER_GRPC_ADDR=127.0.0.1:17891

# Agent hook socket/spool。通常无需手动设置；命名实例会根据 OPENFOCUS_INSTANCE_ID
# 自动使用 ~/.openfocus/hooks-<id>.sock 和 /tmp/openfocus-agent-hooks-<uid>/<id>。
# OPENFOCUS_HOOK_SOCK=
# OPENFOCUS_HOOK_SPOOL_DIR=

# 指定 .env 文件路径（不想放在启动目录时用）
# OPENFOCUS_ENV_FILE=/abs/path/to/.env

# 是否加载 .env（默认 auto：测试环境不自动加载 cwd/.env；显式指定 OPENFOCUS_ENV_FILE 仍会加载）
# OPENFOCUS_DOTENV=auto

# 禁用 gRPC server 自启动（测试/开发时可能有用）
# OPENFOCUS_GRPC_AUTOSTART=0
